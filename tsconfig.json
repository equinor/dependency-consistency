{
	"include": ["*.cjs", "**/*.cjs"],
	"compilerOptions": {
		"target": "ESNext",
		"module": "CommonJS",
		"lib": ["ESNext", "DOM"],
		"types": ["node", "semver-sort"],
		"allowJs": true,
		"checkJs": true,
		"noEmit": true,
		"isolatedModules": false,
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"forceConsistentCasingInFileNames": true
	}
}
